{
  "name": "remarp-vscode",
  "displayName": "Remarp Slides",
  "description": "Author reactive presentations with the remarp markdown format",
  "version": "0.1.0",
  "publisher": "aws-cloud-skills",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atom-oh/oh-my-cloud-skills"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:remarp",
    "onLanguage:markdown",
    "onLanguage:html"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "remarp",
        "aliases": [
          "Remarp",
          "remarp"
        ],
        "extensions": [
          ".remarp.md"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "remarp",
        "scopeName": "text.html.markdown.remarp",
        "path": "./syntaxes/remarp.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "remarp.preview",
        "title": "Remarp: Preview",
        "category": "Remarp",
        "icon": {
          "light": "media/icon.svg",
          "dark": "media/icon.svg"
        }
      },
      {
        "command": "remarp.nextSlide",
        "title": "Next Slide",
        "category": "Remarp"
      },
      {
        "command": "remarp.prevSlide",
        "title": "Previous Slide",
        "category": "Remarp"
      },
      {
        "command": "remarp.toggleEditMode",
        "title": "Remarp: Toggle Visual Edit",
        "category": "Remarp",
        "icon": "$(paintcan)"
      },
      {
        "command": "remarp.build",
        "title": "Remarp: Build HTML",
        "category": "Remarp",
        "icon": "$(rocket)"
      }
    ],
    "keybindings": [
      {
        "command": "remarp.nextSlide",
        "key": "ctrl+shift+right",
        "mac": "cmd+shift+right",
        "when": "editorLangId == remarp || remarp.isRemarpHtml"
      },
      {
        "command": "remarp.prevSlide",
        "key": "ctrl+shift+left",
        "mac": "cmd+shift+left",
        "when": "editorLangId == remarp || remarp.isRemarpHtml"
      },
      {
        "command": "remarp.toggleEditMode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorLangId == remarp || remarp.isRemarpHtml"
      },
      {
        "command": "remarp.build",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorLangId == remarp || remarp.isRemarpHtml"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "remarpOutline",
          "name": "Remarp Slides",
          "when": "editorLangId == remarp || remarp.isRemarpHtml"
        }
      ]
    },
    "configuration": {
      "title": "Remarp",
      "properties": {
        "remarp.buildScriptPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to remarp_to_slides.py. When set, this takes priority over automatic discovery."
        },
        "remarp.scrollSync": {
          "type": "boolean",
          "default": true,
          "description": "Sync editor cursor position with preview slide. When enabled, clicking in the editor scrolls the preview to the corresponding slide."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "remarp.preview",
          "when": "editorLangId == remarp || remarp.isRemarpHtml",
          "group": "navigation"
        },
        {
          "command": "remarp.build",
          "when": "editorLangId == remarp",
          "group": "navigation"
        },
        {
          "command": "remarp.toggleEditMode",
          "when": "editorLangId == remarp || remarp.isRemarpHtml",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
